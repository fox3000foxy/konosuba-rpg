{
  "buildCommand": "",
  "installCommand": "",
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/api/interactions",
      "dest": "/api/interactions.js"
    },
    {
      "src": "/konosuba-rpg/(.*)",
      "dest": "/api/render.js"
    },
    {
      "src": "/(inventory|affinity|quest|shop|profile|achievements)/(.*)",
      "dest": "/api/renderPages.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/light.js"
    }
  ]
}
