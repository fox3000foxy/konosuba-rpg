{
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 320,
    "bracketSameLine": false,
    "bracketSpacing": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "useImportType": {
          "level": "on",
          "options": { "style": "inlineType" }
        }
      }
    }
  },
  "assist": {
    "enabled": false,
    "actions": { "source": { "organizeImports": "on" } }
  }
}