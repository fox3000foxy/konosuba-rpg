{
  "dependencies": {
    "@cf-wasm/photon": "^0.3.4",
    "@resvg/resvg-wasm": "^2.6.2",
    "discord-interactions": "^4.4.0",
    "express": "^4.22.1",
    "hono": "^4.12.9",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  },
  "scripts": {
    "generate:image-manifest": "npx ts-node scripts/generate-image-manifest.ts",
    "tsc:build": "npx tsc",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:perf": "node --expose-gc ./node_modules/jest/bin/jest.js --runInBand --testPathPatterns=tests/perf",
    "test:leaks": "node --expose-gc ./node_modules/jest/bin/jest.js --runInBand --testPathPatterns=tests/perf/leaks.spec.ts",
    "dev": "node scripts/dev.js",
    "dev:node": "npx ts-node-dev --respawn --transpile-only --logger=debug --ignore-watch node_modules src/index.ts",
    "dev:wrangler": "npx wrangler dev",
    "check": "npm run tsc:build && npm run test",
    "lint": "npx eslint src",
    "vercel": "npm run vercel:build && npm run vercel:deploy",
    "vercel:dev": "npx vercel dev --listen 8787",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=.vercel/output/functions/api/index.func/index.js --minify --tree-shaking && node scripts/copy-assets.js",
    "build:watch": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=api/index.js --watch",
    "start": "node api/index.js",
    "vercel:build": "npx vercel build --prod",
    "deploy": "pnpm build && npx vercel deploy --prebuilt --prod"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^1.19.11",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}